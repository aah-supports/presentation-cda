@startuml
skinparam componentStyle rectangle
skinparam shadowing false

actor "Utilisateur (Postman/Browser)" as User

component "Router\n(routes.ts)" as ROUTER
component "MovieController" as MC
component "PageController" as PC
component "MovieService" as SVC
component "MovieRepository\n(in-memory)" as REPO
component "ErrorHandler" as ERR

User --> ROUTER : HTTP /api/*
ROUTER --> MC : /movies
ROUTER --> PC : /pages/home
MC --> SVC
SVC --> REPO
ROUTER --> ERR : exceptions

@enduml
