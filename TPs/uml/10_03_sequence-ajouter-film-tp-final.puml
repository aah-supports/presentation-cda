@startuml
actor Admin
participant "API Controller" as Controller
participant "MovieService" as Service
participant "MovieRepository" as Repo
database "PostgreSQL" as DB

Admin -> Controller: POST /api/movies\n(title, slug, year, duration)
Controller -> Service: createMovie(payload)
Service -> Service: validateBusinessRules()
Service -> Repo: save(movie)
