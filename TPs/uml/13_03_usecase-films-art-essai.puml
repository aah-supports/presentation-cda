@startuml
left to right direction

actor "Visiteur" as Visitor
actor "Utilisateur inscrit" as Member
actor "Modérateur" as Moderator
actor "Administrateur" as Admin

Visitor <|-- Member
Member <|-- Moderator

rectangle "App Films d'art et essai" {
  usecase "Consulter catalogue" as UC1
  usecase "Rechercher film" as UC2
  usecase "Consulter fiche film" as UC3
  usecase "Poster avis" as UC4
  usecase "Vérifier contenu avis" as UC5
  usecase "Modérer avis" as UC6
  usecase "Administrer fiches films" as UC7
}

Visitor --> UC1
Visitor --> UC2
Visitor --> UC3
Member --> UC4
Moderator --> UC6
Admin --> UC7

UC4 .> UC5 : <<include>>
UC6 .> UC4 : <<extend>>

@enduml
