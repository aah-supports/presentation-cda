@startuml
left to right direction
skinparam packageStyle rectangle

actor "Administrateur éditorial" as Admin
actor "Passionné" as Fan
actor "Modérateur" as Mod
actor "Partenaire festival" as Partner

rectangle "App Films d'art et essai" {
  usecase "Consulter le catalogue" as UC1
  usecase "Rechercher un film" as UC2
  usecase "Gérer les fiches films" as UC3
  usecase "Noter et commenter" as UC4
  usecase "Suivre la programmation" as UC5
}

Fan --> UC1
Fan --> UC2
Fan --> UC4
Fan --> UC5
Admin --> UC3
Mod --> UC4
Partner --> UC5

note right of UC3
But : cadrage macro J1
Hypothèse : périmètre MVP
Limite : pas de détails techniques
end note
@enduml
