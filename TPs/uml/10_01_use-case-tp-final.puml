@startuml
left to right direction
skinparam packageStyle rectangle

actor "Utilisateur" as User
actor "Admin" as Admin

rectangle "Systeme Gestion de films" {
  usecase "Lister les films" as UC1
  usecase "Ajouter un film" as UC2
  usecase "Associer un acteur\na un film" as UC3
  usecase "Consulter details film" as UC4
}

User --> UC1
User --> UC4
Admin --> UC1
Admin --> UC2
Admin --> UC3

note right of UC2
But: cadrer les interactions principales
Hypothese: Admin authentifie
Limite: pas de parcours d'erreur detaille
end note
@enduml
